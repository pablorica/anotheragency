# anotheragency
# /etc/nginx/sites-available/anotheragency.conf
server {
  server_name anotheragency.codigo.co.uk;
  client_max_body_size 256m;

 location / {
    proxy_pass http://127.0.0.1:8459;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 300;
    proxy_send_timeout 300;
  }

  # redirect /pma -> /pma/ (prevents missing assets)
  location = /pma {
    return 301 /pma/;
  }

  # phpMyAdmin under a subpath
  location ^~ /pma/ {
    # (optional but recommended) Basic auth
    auth_basic "Restricted";
    auth_basic_user_file /srv/docker/anotheragency/.htpasswd-pma;

    # Strip /pma prefix when proxying
    proxy_pass http://127.0.0.1:8109/;
    proxy_http_version 1.1;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Port  443;

    proxy_read_timeout 300;
    proxy_send_timeout 300;
  }
}