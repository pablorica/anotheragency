{
  "__preprocessed__": "This file is used to build the theme.json file in the `public/build/assets` directory. The built artifact includes Tailwind's colors, fonts, and font sizes.",
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "layout": {
      "contentSize": "48rem"
    },
    "background": {
      "backgroundImage": true
    },
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [],
      "palette": [
        { "name": "Black", "slug": "black", "color": "#000" },
        { "name": "Orange", "slug": "orange", "color": "#F5532D" },
        { "name": "White", "slug": "white", "color": "#fff" }
      ]
    },
    "custom": {
      "spacing": {},
      "typography": {
        "font-size": {},
        "line-height": {}
      }
    },
    "spacing": {
      "padding": true,
      "units": ["px", "%", "em", "rem", "vw", "vh"]
    },
    "typography": {
      "defaultFontSizes": false,
      "customFontSize": false
    }
  },
  "styles": {
    "elements": {
      "button": {
        "color": {
          "text": "var:preset|color|orange",
          "background": "transparent"
        },
        "typography": {
          "textDecoration": "underline"
        },
        "spacing": {
          "padding": {
            "top": "20px",
            "right": "20px",
            "bottom": "20px",
            "left": "20px"
          }
        },
        "border": {
          "radius": "10px"
        }
      }
    }
  }
}
